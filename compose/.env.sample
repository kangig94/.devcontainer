# =============================================================================
# ML Dev Container Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment:
#   cp compose/.env.sample compose/.env
#
# IMPORTANT: .env is gitignored and should contain your actual paths/credentials
# =============================================================================

# -----------------------------------------------------------------------------
# User Settings
# -----------------------------------------------------------------------------
# USER_UID/USER_GID auto-detected by Makefile via `id -u` / `id -g`.
# Image bakes dev (UID 1000); entrypoint.sh remaps to USER_UID at startup.
# USERNAME is fixed to `dev` by image/entrypoint.

# -----------------------------------------------------------------------------
# Docker Registry (REQUIRED - set your own registry)
# -----------------------------------------------------------------------------
# Examples:
#   - Docker Hub: your-dockerhub-username
#   - Private registry: harbor.company.com/ml-team
#   - AWS ECR: 123456789.dkr.ecr.us-east-1.amazonaws.com
DOCKER_REGISTRY=your-registry

# -----------------------------------------------------------------------------
# NAS/Storage Configuration
# -----------------------------------------------------------------------------
# Base path for NAS mounts (defaults to $HOME for local development)
# Examples:
#   - Local: $HOME (default)
#   - Linux NAS: /mnt/nas/users/username
#   - macOS NAS: /Volumes/nas/users/username
NAS_HOME=$HOME

# Host mount paths (uses NAS_HOME as base, or set directly for local dev)
HOST_WORKSPACE_DIR=${NAS_HOME}/workspace
HOST_CACHE_DIR=${NAS_HOME}/.cache
HOST_DATASETS_DIR=${NAS_HOME}/datasets

# Optional: Override Claude CLI data path (default: ${NAS_HOME}/.claude-dev)
# HOST_CLAUDE_DIR=${NAS_HOME}/.claude-dev

# -----------------------------------------------------------------------------
# Local Development (WSL/macOS without NAS)
# -----------------------------------------------------------------------------
# Uncomment and modify for local development:
# NAS_HOME=
# HOST_WORKSPACE_DIR=/home/username/workspace
# HOST_CACHE_DIR=~/.cache
# HOST_DATASETS_DIR=~/datasets

# -----------------------------------------------------------------------------
# Port Mapping (change if port conflicts)
# -----------------------------------------------------------------------------
# PORT_JUPYTER=18888
# PORT_TENSORBOARD=16006
# PORT_GRADIO=17860
# PORT_SSH=10022

# -----------------------------------------------------------------------------
# Docker Network
# -----------------------------------------------------------------------------
# Change if conflicts with your VPN or internal network
# DOCKER_SUBNET=192.168.10.0/24

# -----------------------------------------------------------------------------
# Image Configuration (overridden by Makefile via py= / torch= / cu= flags)
# -----------------------------------------------------------------------------
# IMAGE_NAME=uv-torch
# PY_TAG=py312
# TORCH_VERSION=2.10.0
# CUDA_TAG=cu128

# Parallel jobs for source builds (flash-attn / deepspeed). Default 2.
# Each job uses ~4-8GB RAM. nproc/2 has frozen 32-core hosts before — raise carefully.
# MAX_JOBS=2

# -----------------------------------------------------------------------------
# Claude Code CLI (Optional)
# -----------------------------------------------------------------------------
# CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=true
