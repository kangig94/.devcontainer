# =============================================================================
# Isaac Lab 3.0.0-beta Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Isaac Lab (baked into image at /opt/isaaclab)
# -----------------------------------------------------------------------------
ISAACLAB_PATH=/opt/isaaclab
ISAACLAB_VERSION=v3.0.0-beta

# Python (3.12 required for Isaac Lab 3.0)
PYTHON_VERSION=3.12

# -----------------------------------------------------------------------------
# Isaac Sim base image (heavy deps bundled: PyTorch, Warp, MuJoCo, Newton)
# -----------------------------------------------------------------------------
ISAACSIM_IMAGE=nvcr.io/nvidia/isaac-sim:6.0.0-dev2

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
# Container uses network_mode: host, so no port mapping needed.
# Default ports used by services inside the container:
#   - viser:    8080 (browser visualizer)
#   - jupyter:  8888
#   - rerun:    9876
#   - webrtc:   49100 (signal) / 47998 (stream)
